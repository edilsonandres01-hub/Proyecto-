generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  country   String    @default("MX")
  taxId     String?
  phone     String?
  createdAt DateTime  @default(now())
  users     User[]
  products  Product[]
  orders    Order[]
  payments  Payment[]
  invoices  Invoice[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  priceCents  Int
  currency    String   @default("MXN")
  stockQty    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  status      String      @default("draft")
  totalCents  Int         @default(0)
  currency    String      @default("MXN")
  customerName String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  payments    Payment[]
  invoices    Invoice[]

  @@index([tenantId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPriceCents Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  rail        String
  status      String   @default("pending")
  amountCents Int
  currency    String   @default("MXN")
  intentId    String?
  instructions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
}

model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  country     String
  status      String   @default("issued")
  uuidOrChave String?
  pdfStubUrl  String?
  xmlStub     String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
}
