# Copy to .env — absolute path avoids SQLite cwd issues across workspaces
DATABASE_URL="file:/absolute/path/to/packages/db/prisma/dev.db"
# Optional overrides (demo defaults work without these)
# PYMEBOT_API_KEY=pymebot_demo_key
# PYMEBOT_WEBHOOK_SECRET=pymebot_webhook_secret
# Feature flags: JSON object or comma-separated disabled list
# PYMEBOT_FLAGS={"billing":false}
# PYMEBOT_FLAGS=billing,webhooks

